---
import type { TeachingItem } from '../../../shared/types';
import teachingData from '../../../data/teaching/teaching.json';

interface Props {
  title?: string;
}

const { title = 'Teaching Experience' } = Astro.props;
const items = teachingData.items as TeachingItem[];
---

<section class="teaching-section">
  <h2 class="section-title">{title}</h2>

  {items && items.length > 0 ? (
    <div class="teaching-list">
      {items.map((item) => (
        <article class="teaching-item">
          <div class="item-header">
            <h3 class="item-title">{item.title}</h3>
            {item.period && <span class="item-year">{item.period}</span>}
          </div>

          {item.institution && (
            <p class="item-institution">{item.institution}</p>
          )}

          {item.role && <p class="item-role">{item.role}</p>}

          {item.summary && (
            <p class="item-description">{item.summary}</p>
          )}

          {item.materialsUrl && (
            <a href={item.materialsUrl} target="_blank" rel="noopener noreferrer" class="item-link">
              View materials →
            </a>
          )}
        </article>
      ))}
    </div>
  ) : (
    <div class="empty-state">
      <p>No teaching experience to display at this time.</p>
      <p class="empty-subtitle">Updates coming soon!</p>
    </div>
  )}
</section>

<style>
  .teaching-section {
    margin-bottom: var(--space-6);
  }

  .section-title {
    font-size: 1.25rem;
    font-weight: 700;
    margin: 0 0 var(--space-6) 0;
    color: var(--color-text);
  }

  .teaching-list {
    display: grid;
    gap: var(--space-6);
  }

  .teaching-item {
    padding: var(--space-6);
    border: 1px solid var(--color-border);
    border-left: 3px solid var(--color-accent);
    border-radius: var(--radius-lg);
    background-color: var(--color-surface-soft);
    transition: all var(--transition-base);
  }

  .teaching-item:hover {
    border-left-color: var(--color-accent);
    background-color: var(--color-surface);
  }

  .item-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: var(--space-4);
    margin-bottom: var(--space-2);
  }

  .item-title {
    margin: 0;
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-text);
  }

  .item-year {
    display: inline-block;
    padding: var(--space-1) var(--space-2);
    background-color: var(--color-surface);
    border-radius: var(--radius-sm);
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--color-text-muted);
    flex-shrink: 0;
  }

  .item-institution {
    margin: 0 0 var(--space-1) 0;
    font-size: 1rem;
    color: var(--color-text-muted);
  }

  .item-role {
    margin: 0 0 var(--space-2) 0;
    font-size: 0.875rem;
    color: var(--color-text-muted);
    font-style: italic;
  }

  .item-description {
    margin: 0 0 var(--space-3) 0;
    font-size: 0.875rem;
    color: var(--color-text-muted);
    line-height: 1.5;
  }

  .item-link {
    display: inline-block;
    font-size: 0.875rem;
    color: var(--color-accent);
    text-decoration: none;
    font-weight: 600;
  }

  .item-link:hover {
    text-decoration: underline;
  }

  .empty-state {
    padding: var(--space-8);
    text-align: center;
    color: var(--color-text-muted);
    border: 1px dashed var(--color-border);
    border-radius: var(--radius-lg);
    background-color: var(--color-surface-soft);
  }

  .empty-state p {
    margin: 0 0 var(--space-2) 0;
    font-size: 1rem;
  }

  .empty-state p:last-child {
    margin: 0;
  }

  .empty-subtitle {
    font-size: 0.875rem;
    color: var(--color-text-muted);
  }

  @media (max-width: 768px) {
    .item-header {
      flex-direction: column;
    }

    .item-year {
      align-self: flex-start;
    }
  }
</style>
