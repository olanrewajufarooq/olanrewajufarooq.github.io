---
import profileData from '../../../data/site/profile.json';
---

<div class="affiliation-meta">
  <div class="affiliation-item">
    <span class="affiliation-label">Current Position:</span>
    <span class="affiliation-value">{profileData.title}</span>
  </div>
  <div class="affiliation-item">
    <span class="affiliation-label">Institution:</span>
    <span class="affiliation-value">{profileData.institution}</span>
  </div>
  {profileData.email && (
    <div class="affiliation-item">
      <span class="affiliation-label">Email:</span>
      <a href={`mailto:${profileData.email}`} class="affiliation-value">
        {profileData.email}
      </a>
    </div>
  )}
</div>

<style>
  .affiliation-meta {
    display: grid;
    gap: var(--space-4);
    padding: var(--space-4) 0;
  }

  .affiliation-item {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .affiliation-label {
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-semibold);
    color: var(--color-text-secondary);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .affiliation-value {
    font-size: var(--font-size-base);
    color: var(--color-text);
    font-weight: var(--font-weight-medium);

    &[href] {
      color: var(--color-link);

      &:hover {
        text-decoration: underline;
      }
    }
  }
</style>
