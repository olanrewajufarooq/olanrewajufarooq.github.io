---
import SectionHeading from '../../../components/ui/SectionHeading.astro';
import styles from '../styles/home.module.css';
---

<section class={styles.section}>
  <SectionHeading eyebrow="Focus" title="Research Focus" />
  <div class={styles.proseBlock}>
    <p>
      My work focuses on geometric control, vehicle-manipulator systems, autonomous robotics,
      and safe interaction in complex engineered systems.
    </p>
    <p>
      I am particularly interested in developing mathematically grounded control frameworks that
      remain useful for real robotic platforms and future experimental research.
    </p>
  </div>
</section>