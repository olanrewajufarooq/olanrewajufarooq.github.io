---
import SectionHeading from '../../../components/ui/SectionHeading.astro';
import styles from '../styles/home.module.css';
import type { ResearchThemeSummary } from '../../../shared/types/research';

interface Props {
  themes: ResearchThemeSummary[];
}

const { themes } = Astro.props;
---

<section class={styles.section}>
  <SectionHeading eyebrow="Research" title="Featured Research Themes" />
  <div class={styles.themeList}>
    {themes.map((theme) => (
      <article class={styles.themeItem}>
        <h3 class={styles.themeTitle}>
          <a href={`/research/${theme.slug}`}>{theme.title}</a>
        </h3>
        <p class={styles.themePeriod}>{theme.period}</p>
        <p class={styles.themeSummary}>{theme.summary}</p>
        <ul class={styles.keywordList}>
          {theme.keywords.slice(0, 4).map((keyword) => (
            <li>{keyword}</li>
          ))}
        </ul>
      </article>
    ))}
  </div>
</section>