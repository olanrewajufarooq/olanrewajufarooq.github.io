---
import ButtonLink from '../../../components/ui/ButtonLink.astro';
import styles from '../styles/home.module.css';
---

<section class={styles.section}>
  <div class={styles.callout}>
    <h2 class={styles.calloutTitle}>Open to Collaboration</h2>
    <p>
      I am interested in collaborations in geometric control, autonomous robotics,
      vehicle-manipulator systems, and related control-oriented research areas.
    </p>
    <div class={styles.heroActions}>
      <ButtonLink href="/research" variant="primary">View Research Portfolio</ButtonLink>
      <ButtonLink href="mailto:olanrewajufarooq@yahoo.com" variant="secondary">Get in Touch</ButtonLink>
    </div>
  </div>
</section>