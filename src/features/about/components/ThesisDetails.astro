---
import styles from '../styles/about.module.css';
import type { Thesis } from '../../../shared/types/education';

interface Props {
  thesis: Thesis;
}

const { thesis } = Astro.props;
---

<details class={styles.thesisDetails}>
  <summary class={styles.thesisSummary}>View thesis details</summary>

  <div class={styles.thesisContent}>
    <p>
      <strong>Title:</strong> {thesis.title}
    </p>

    {thesis.advisor.length > 0 && (
      <p>
        <strong>Advisor{thesis.advisor.length > 1 ? 's' : ''}:</strong>{' '}
        {thesis.advisor.map((advisor, index) => (
          <>
            {index > 0 && ', '}
            {advisor.url ? (
              <a href={advisor.url} target="_blank" rel="noopener noreferrer">
                {advisor.name}
              </a>
            ) : (
              advisor.name
            )}
          </>
        ))}
      </p>
    )}

    {thesis.lab?.name && (
      <p>
        <strong>Lab:</strong>{' '}
        {thesis.lab.url ? (
          <a href={thesis.lab.url} target="_blank" rel="noopener noreferrer">
            {thesis.lab.name}
          </a>
        ) : (
          thesis.lab.name
        )}
      </p>
    )}

    {thesis.relatedResearchSlug && (
      <p>
        <strong>Related research:</strong>{' '}
        <a href={`/research/${thesis.relatedResearchSlug}`}>View research theme</a>
      </p>
    )}
  </div>
</details>
