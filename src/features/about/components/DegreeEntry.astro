---
import ThesisDetails from './ThesisDetails.astro';
import styles from '../styles/about.module.css';
import type { SingleDegreeEntry } from '../../../shared/types/education';

interface Props {
  degree: SingleDegreeEntry;
}

const { degree } = Astro.props;
---

<article class={styles.educationItem}>
  <div class={styles.educationHeader}>
    <div class={styles.educationMain}>
      <h3 class={styles.degreeInstitution}>
        {degree.url ? (
          <a href={degree.url} target="_blank" rel="noopener noreferrer">
            {degree.institution}
          </a>
        ) : (
          degree.institution
        )}
      </h3>

      <p class={styles.degreeMeta}>
        <strong>{degree.degree}</strong> in {degree.field}
      </p>

      <p class={styles.degreeSubmeta}>
        <span>{degree.location}</span>
        <span aria-hidden="true"> · </span>
        <span>{degree.period}</span>
      </p>
    </div>

    {degree.logo && (
      <div class={styles.educationLogoWrap}>
        <img src={degree.logo} alt="" aria-hidden="true" class={styles.educationLogo} />
      </div>
    )}
  </div>

  {degree.thesis && <ThesisDetails thesis={degree.thesis} />}
</article>
