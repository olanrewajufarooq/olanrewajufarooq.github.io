---
import SectionHeading from '../../../components/ui/SectionHeading.astro';
import educationData from '../../../data/about/education.json';
import type { DegreeEntry } from '../../../shared/types';
import { isJointDegree } from '../../../shared/types';

interface Props {
  title?: string;
}

const { title = 'Education' } = Astro.props;
const degrees = educationData.degrees as DegreeEntry[];
---

<section class="education-section">
  <SectionHeading title={title} />
  <div class="education-timeline">
    {degrees.map((degree) => (
      <article class:list={['education-entry', { 'joint-degree': isJointDegree(degree) }]}>
        {isJointDegree(degree) ? (
          <>
            <h3 class="degree-name">{degree.programName}</h3>
            <div class="joint-degree-group">
              {degree.entries.map((entry) => (
                <div class="degree-part">
                  <div class="degree-level">{entry.degree}</div>
                  <div class="degree-field">{entry.field}</div>
                  <div class="degree-location">{entry.location}</div>
                  <div class="degree-period">{entry.period}</div>
                  {entry.url && (
                    <a href={entry.url} target="_blank" rel="noopener noreferrer" class="institution-link">
                      {entry.institution}
                    </a>
                  )}
                  {entry.logo && (
                    <img src={entry.logo} alt={entry.institution} class="institution-logo" />
                  )}
                </div>
              ))}
            </div>
          </>
        ) : (
          <>
            <h3 class="degree-name">{degree.degree}</h3>
            <p class="degree-field">{degree.field}</p>
            <p class="degree-location">{degree.location}</p>
            <p class="degree-period">{degree.period}</p>
            {degree.url && (
              <a href={degree.url} target="_blank" rel="noopener noreferrer" class="institution-link">
                {degree.institution}
              </a>
            )}
            {degree.logo && (
              <img src={degree.logo} alt={degree.institution} class="institution-logo" />
            )}
          </>
        )}

        {degree.thesis && (
          <div class="thesis-section">
            <h4 class="thesis-title">Thesis</h4>
            <p class="thesis-name">{degree.thesis.title}</p>
            {degree.thesis.advisor && degree.thesis.advisor.length > 0 && (
              <div class="thesis-advisor">
                <span class="label">Advisor:</span>
                {degree.thesis.advisor.length > 1 ? (
                  <ul class="advisor-list">
                    {degree.thesis.advisor.map((advisor, idx) => (
                      <li>
                        {advisor.url ? (
                          <a href={advisor.url} target="_blank" rel="noopener noreferrer">
                            {advisor.name}
                          </a>
                        ) : (
                          advisor.name
                        )}
                      </li>
                    ))}
                  </ul>
                ) : (
                  <>
                    {degree.thesis.advisor[0].url ? (
                      <a href={degree.thesis.advisor[0].url} target="_blank" rel="noopener noreferrer">
                        {degree.thesis.advisor[0].name}
                      </a>
                    ) : (
                      <span>{degree.thesis.advisor[0].name}</span>
                    )}
                  </>
                )}
              </div>
            )}
            {degree.thesis.lab && (
              <div class="thesis-lab">
                <span class="label">Lab:</span>
                {degree.thesis.lab.url ? (
                  <a href={degree.thesis.lab.url} target="_blank" rel="noopener noreferrer">
                    {degree.thesis.lab.name}
                  </a>
                ) : (
                  <span>{degree.thesis.lab.name}</span>
                )}
              </div>
            )}
          </div>
        )}
      </article>
    ))}
  </div>
</section>

<style>
  .education-section {
    margin-bottom: var(--space-16);
  }

  .education-timeline {
    display: grid;
    gap: var(--space-8);
  }

  .education-entry {
    padding: var(--space-6);
    border-left: 3px solid var(--color-primary);
    border-radius: var(--radius-lg);
    background-color: var(--color-bg-secondary);
  }

  .degree-name {
    margin: 0 0 var(--space-3) 0;
    font-size: var(--font-size-xl);
    font-weight: var(--font-weight-semibold);
    color: var(--color-text);
  }

  .degree-field {
    margin: 0 0 var(--space-2) 0;
    color: var(--color-text-secondary);
    font-size: var(--font-size-base);
  }

  .degree-location {
    margin: 0 0 var(--space-2) 0;
    font-size: var(--font-size-sm);
    color: var(--color-text-tertiary);
  }

  .degree-period {
    margin: 0 0 var(--space-3) 0;
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-semibold);
    color: var(--color-text-secondary);
  }

  .institution-link {
    display: inline-block;
    color: var(--color-link);
    font-size: var(--font-size-sm);
    margin-bottom: var(--space-3);
    text-decoration: none;

    &:hover {
      text-decoration: underline;
    }
  }

  .institution-logo {
    display: block;
    max-height: 60px;
    width: auto;
    margin-top: var(--space-3);
    opacity: 0.8;
  }

  .joint-degree-group {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: var(--space-4);
    margin: var(--space-4) 0;
    padding: var(--space-4);
    background-color: var(--color-bg-tertiary);
    border-radius: var(--radius-md);
  }

  .degree-part {
    padding: var(--space-3);
  }

  .degree-level {
    font-weight: var(--font-weight-semibold);
    margin-bottom: var(--space-2);
    color: var(--color-text);
  }

  .thesis-section {
    margin-top: var(--space-6);
    padding-top: var(--space-6);
    border-top: 1px solid var(--color-border);
  }

  .thesis-title {
    font-size: var(--font-size-base);
    font-weight: var(--font-weight-semibold);
    margin: 0 0 var(--space-2) 0;
    color: var(--color-text-secondary);
  }

  .thesis-name {
    margin: 0 0 var(--space-3) 0;
    font-style: italic;
    color: var(--color-text);
    line-height: 1.5;
  }

  .thesis-advisor,
  .thesis-lab {
    margin: var(--space-2) 0;
    font-size: var(--font-size-sm);
  }

  .label {
    font-weight: var(--font-weight-semibold);
    color: var(--color-text-secondary);
    margin-right: var(--space-2);
  }

  .advisor-list {
    display: inline-block;
    list-style: none;
    padding: 0;
    margin: 0;

    li {
      display: inline;

      &:not(:last-child)::after {
        content: ', ';
      }

      a {
        color: var(--color-link);
        text-decoration: none;

        &:hover {
          text-decoration: underline;
        }
      }
    }
  }

  @media (max-width: var(--breakpoint-md)) {
    .joint-degree-group {
      grid-template-columns: 1fr;
    }
  }
</style>
