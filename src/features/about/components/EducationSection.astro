---
import educationData from '../../../data/about/education.json';
import SectionHeading from '../../../components/ui/SectionHeading.astro';
import DegreeEntry from './DegreeEntry.astro';
import JointDegreeGroup from './JointDegreeGroup.astro';
import styles from '../styles/about.module.css';
import type { DegreeEntry as DegreeEntryType } from '../../../shared/types/education';

const degrees = educationData.degrees as DegreeEntryType[];
---

<section class={styles.section}>
  <SectionHeading eyebrow="Education" title="Academic Background" />

  <div class={styles.educationList}>
    {degrees.map((degree) =>
      degree.type === 'single' ? (
        <DegreeEntry degree={degree} />
      ) : (
        <JointDegreeGroup degree={degree} />
      )
    )}
  </div>
</section>
