---
import awardsData from '../../../data/about/awards.json';
import SectionHeading from '../../../components/ui/SectionHeading.astro';
import styles from '../styles/about.module.css';
import type { AwardsData } from '../../../shared/types/award';

const data = awardsData as AwardsData;
const awards = data.awards;
---

<section class={styles.section}>
  <SectionHeading eyebrow="Awards" title="Awards and Recognition" />

  {awards.length > 0 ? (
    <ul class={styles.awardsList}>
      {awards.map((award) => (
        <li class={styles.awardItem}>
          <h3 class={styles.awardTitle}>{award.title}</h3>
          <p class={styles.awardMeta}>
            {award.issuer} · {award.date}
          </p>
          {award.description && <p>{award.description}</p>}
          {award.url && (
            <p>
              <a href={award.url} target="_blank" rel="noopener noreferrer">
                View details
              </a>
            </p>
          )}
        </li>
      ))}
    </ul>
  ) : (
    <div class={styles.emptyBlock}>
      <p>Awards and recognitions will appear here as they are added.</p>
    </div>
  )}
</section>
