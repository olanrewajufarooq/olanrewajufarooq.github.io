---
import profile from '../../../data/site/profile.json';
import SectionHeading from '../../../components/ui/SectionHeading.astro';
import styles from '../styles/about.module.css';
---

<section class={styles.section}>
  <SectionHeading eyebrow="About" title="Academic Profile" />
  <div class={styles.introBlock}>
    <p>
      I am a <strong>{profile.title}</strong> in <strong>{profile.department}</strong> at
      <strong> {profile.institution}</strong>.
    </p>
    <p>
      My research interests span geometric control, autonomous robotics, vehicle-manipulator systems,
      and safe physical human-robot interaction. I am particularly interested in building rigorous
      control-oriented frameworks that remain meaningful for practical robotic systems.
    </p>
  </div>
</section>
