---
import profile from '../../../data/site/profile.json';
import ButtonLink from '../../../components/ui/ButtonLink.astro';
import SectionHeading from '../../../components/ui/SectionHeading.astro';
import styles from '../styles/about.module.css';
---

<section class={styles.section}>
  <SectionHeading eyebrow="CV" title="Curriculum Vitae" />

  <div class={styles.cvPanel}>
    <div class={styles.cvPanelText}>
      <p>
        A current PDF version of my curriculum vitae is available for download.
      </p>
    </div>

    <div class={styles.cvPanelActions}>
      <ButtonLink href={profile.cvPath} variant="primary">
        Download CV
      </ButtonLink>
    </div>
  </div>
</section>
