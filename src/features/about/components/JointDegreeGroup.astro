---
import ThesisDetails from './ThesisDetails.astro';
import styles from '../styles/about.module.css';
import type { JointDegreeEntry } from '../../../shared/types/education';

interface Props {
  degree: JointDegreeEntry;
}

const { degree } = Astro.props;
---

<article class={styles.educationItem}>
  <header class={styles.jointHeader}>
    <h3 class={styles.degreeInstitution}>{degree.programName}</h3>
  </header>

  <div class={styles.jointEntries}>
    {degree.entries.map((entry) => (
      <div class={styles.jointEntry}>
        <div class={styles.educationHeader}>
          <div class={styles.educationMain}>
            <h4 class={styles.jointInstitution}>
              {entry.url ? (
                <a href={entry.url} target="_blank" rel="noopener noreferrer">
                  {entry.institution}
                </a>
              ) : (
                entry.institution
              )}
            </h4>

            <p class={styles.degreeMeta}>
              <strong>{entry.degree}</strong> in {entry.field}
            </p>

            <p class={styles.degreeSubmeta}>
              <span>{entry.location}</span>
              <span aria-hidden="true"> · </span>
              <span>{entry.period}</span>
            </p>
          </div>

          {entry.logo && (
            <div class={styles.educationLogoWrap}>
              <img src={entry.logo} alt="" aria-hidden="true" class={styles.educationLogo} />
            </div>
          )}
        </div>
      </div>
    ))}
  </div>

  {degree.thesis && <ThesisDetails thesis={degree.thesis} />}
</article>
