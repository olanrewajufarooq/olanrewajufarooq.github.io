---
import ContentLayout from '../layouts/ContentLayout.astro';
import HomeHero from '../features/home/components/HomeHero.astro';
import ResearchFocusSection from '../features/home/components/ResearchFocusSection.astro';
import CurrentAffiliationSection from '../features/home/components/CurrentAffiliationSection.astro';
import NowSection from '../features/home/components/NowSection.astro';
import FeaturedThemesSection from '../features/home/components/FeaturedThemesSection.astro';
import LatestWorkSection from '../features/home/components/LatestWorkSection.astro';
import CollaborationSection from '../features/home/components/CollaborationSection.astro';
import {
  getFeaturedThemes,
  getLatestAcceptedOrPublishedPublication,
  getCurrentProjects
} from '../shared/content/home';
import { buildMetadata, getCanonicalUrl } from '../shared/content/metadata';

const featuredThemes = getFeaturedThemes();
const latestPublication = getLatestAcceptedOrPublishedPublication();
const currentProjects = getCurrentProjects();

const meta = buildMetadata({
  title: 'Farooq Olanrewaju | PhD Student in Robotics and Control',
  description: 'Academic portfolio of Farooq Olanrewaju, PhD Student in robotics, control engineering, and autonomous systems research.',
  canonical: getCanonicalUrl('/'),
  image: '/assets/images/me/headshot.png',
});
---

<ContentLayout
  title={meta.title}
  description={meta.description}
  activePath="/"
  canonical={meta.canonical}
  ogImage={meta.openGraph?.image}
>
  <HomeHero />
  <ResearchFocusSection />
  <CurrentAffiliationSection />
  <NowSection />
  <FeaturedThemesSection themes={featuredThemes} />
  <LatestWorkSection publication={latestPublication} projects={currentProjects} />
  <CollaborationSection />
</ContentLayout>
