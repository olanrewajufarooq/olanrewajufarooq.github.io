---
import ContentLayout from '../layouts/ContentLayout.astro';
import PageHero from '../components/layout/PageHero.astro';
import Sidebar from '../components/layout/Sidebar.astro';
import Footer from '../components/layout/Footer.astro';
import SiteShell from '../components/layout/SiteShell.astro';
import IdentityBlock from '../features/profile/components/IdentityBlock.astro';
import SocialLinks from '../features/profile/components/SocialLinks.astro';
import AffiliationMeta from '../features/profile/components/AffiliationMeta.astro';
import AboutIntro from '../features/about/components/AboutIntro.astro';
import EducationSection from '../features/about/components/EducationSection.astro';
import CertificatesSection from '../features/about/components/CertificatesSection.tsx';
import AwardsSection from '../features/about/components/AwardsSection.astro';
import CvDownloadPanel from '../features/about/components/CvDownloadPanel.astro';
---

<ContentLayout title="About | Farooq Olanrewaju" description="Education and background of Farooq Olanrewaju" activePath="/about">
  <main class="about-content">
    <AboutIntro />
    <EducationSection />
    <CertificatesSection client:load />
    <AwardsSection />
    <CvDownloadPanel />
  </main>
</ContentLayout>

<style>
  .about-content {
    max-width: 900px;
    margin: 0 auto;
  }
</style>
