---
import ContentLayout from '../layouts/ContentLayout.astro';
import AboutIntro from '../features/about/components/AboutIntro.astro';
import EducationSection from '../features/about/components/EducationSection.astro';
import CertificatesSection from '../features/about/components/CertificatesSection';
import AwardsSection from '../features/about/components/AwardsSection.astro';
import CvDownloadPanel from '../features/about/components/CvDownloadPanel.astro';
import { buildMetadata, getCanonicalUrl } from '../shared/content/metadata';

const meta = buildMetadata({
  title: 'About | Farooq Olanrewaju',
  description: 'About Farooq Olanrewaju, including education, certifications, awards, and CV.',
  canonical: getCanonicalUrl('/about'),
});
---

<ContentLayout
  title={meta.title}
  description={meta.description}
  activePath="/about"
  canonical={meta.canonical}
  ogImage={meta.openGraph?.image}
>
  <AboutIntro />
  <EducationSection />
  <CertificatesSection client:load />
  <AwardsSection />
  <CvDownloadPanel />
</ContentLayout>
