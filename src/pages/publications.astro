---
import ContentLayout from '../layouts/ContentLayout.astro';
import PublicationsIntro from '../features/publications/components/PublicationsIntro.astro';
import PublicationsList from '../features/publications/components/PublicationsList.tsx';
import publicationsData from '../data/publications/publications.json';
import type { Publication } from '../shared/types';
import { buildMetadata, getCanonicalUrl } from '../shared/content/metadata';

const publications = publicationsData.publications as Publication[];

const meta = buildMetadata({
  title: 'Publications | Farooq Olanrewaju',
  description: 'Accepted and published works by Farooq Olanrewaju in robotics, control, and autonomous systems.',
  canonical: getCanonicalUrl('/publications'),
});
---

<ContentLayout
  title={meta.title}
  description={meta.description}
  activePath="/publications"
  canonical={meta.canonical}
  ogImage={meta.openGraph?.image}
>
  <main class="publications-content">
    <PublicationsIntro />
    <PublicationsList client:load publications={publications} />
  </main>
</ContentLayout>

<style>
  .publications-content {
    max-width: 900px;
    margin: 0 auto;
  }
</style>

