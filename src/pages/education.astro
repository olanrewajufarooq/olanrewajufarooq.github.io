---
import MainLayout from '../layouts/MainLayout.astro';
import Hero from '../components/Hero.astro';
import educationData from '../data/education.json';
import moocData from '../data/mooc.json';

const degrees = educationData.degrees as any[];
const certs = moocData.certificates;

const techStack = [
  { name: 'Python',   logo: '/assets/images/logos/python.svg' },
  { name: 'MATLAB',   logo: '/assets/images/logos/matlab.png' },
  { name: 'C++',      logo: '/assets/images/logos/cpp.png' },
  { name: 'ROS 2',    logoDark: '/assets/images/logos/ros2-white.svg',  logoLight: '/assets/images/logos/ros2.svg' },
  { name: 'Gazebo',   logoDark: '/assets/images/logos/gazebo-dark.svg', logoLight: '/assets/images/logos/gazebo.svg' },
  { name: 'Git',      logo: '/assets/images/logos/git.svg' },
  { name: 'Ubuntu',   logoDark: '/assets/images/logos/ubuntu-dark.svg', logoLight: '/assets/images/logos/ubuntu.svg' },
];

function buildAdvisorProse(
  advisor: string | string[] | null,
  advisorLink: string | string[] | null,
  lab: string | null,
  labLink: string | null
): string | null {
  if (!advisor) return null;
  const advisors: string[] = Array.isArray(advisor) ? advisor : [advisor];
  const links: (string | null)[] = Array.isArray(advisorLink) ? advisorLink : [advisorLink];
  const parts = advisors.map((a, i) =>
    links[i] ? `<a href="${links[i]}" target="_blank" rel="noopener noreferrer">${a}</a>` : a
  );
  const verb = advisors.length > 1 ? 'co-supervised' : 'supervised';
  const who = advisors.length === 1
    ? parts[0]
    : parts.slice(0, -1).join(', ') + ' and ' + parts[parts.length - 1];
  let prose = `The thesis associated with this degree was ${verb} by ${who}`;
  if (lab) {
    const labStr = labLink
      ? `<a href="${labLink}" target="_blank" rel="noopener noreferrer">${lab}</a>`
      : lab;
    prose += ` at the ${labStr}`;
  }
  return prose + '.';
}
---

<MainLayout
  title="Education | Farooq Olanrewaju"
  description="Academic background, degrees, tech stack and professional certificates of Farooq Olanrewaju."
  activePath="/education"
>
  <Hero slot="hero" variant="sm" title="Education" subtitle="Academic Background & Continuous Learning" />

  <!-- Degrees -->
  <section class="content-section" id="degrees">
    <h2>Academic Degrees</h2>
    <div class="edu-timeline">
      {degrees.map((deg: any) => {

        /* ── Joint / Erasmus Mundus entry ── */
        if (deg.jointdegree) {
          const advisorProse = buildAdvisorProse(deg.advisor, deg.advisorLink, deg.lab, deg.labLink);
          return (
            <div class="edu-timeline-item">
              <div class="edu-tl-dot"></div>
              <div class="edu-tl-jd-wrapper">
                <p class="edu-tl-jd-name">{deg.JDName}</p>
                <div class="edu-tl-jd-institutions">
                  {(deg.institution as string[]).map((_: string, i: number) => (
                    <div class="edu-tl-panel edu-tl-sub-panel">
                      <div class="edu-tl-body">
                        <p class="edu-tl-institution">
                          {deg.url[i] ? (
                            <a href={deg.url[i]} target="_blank" rel="noopener noreferrer" class="edu-tl-inst-link">{deg.institution[i]}</a>
                          ) : <span>{deg.institution[i]}</span>}
                          {deg.location[i] && <span class="edu-tl-sep-dot">·</span>}
                          {deg.location[i] && <span class="edu-tl-location">{deg.location[i]}</span>}
                        </p>
                        <p class="edu-tl-degree">
                          <span class="edu-tl-degree-name">{deg.degree[i]}</span>
                          <span class="edu-tl-sep"> · </span>
                          <span class="edu-tl-field">{deg.field[i]}</span>
                        </p>
                        <p class="edu-tl-period">{deg.period[i]}</p>
                      </div>
                      {deg.logo[i] && (
                        <img src={deg.logo[i]} alt={deg.institution[i]} class="edu-tl-logo" onerror="this.style.display='none'" />
                      )}
                    </div>
                  ))}
                </div>
                {advisorProse && (
                  <p class="edu-tl-advisor" set:html={advisorProse} />
                )}
              </div>
            </div>
          );
        }

        /* ── Regular single entry ── */
        const advisorProse = buildAdvisorProse(deg.advisor, deg.advisorLink, deg.lab, deg.labLink);
        return (
          <div class="edu-timeline-item">
            <div class="edu-tl-dot"></div>
            <div class="edu-tl-panel">
              <div class="edu-tl-body">
                <p class="edu-tl-institution">
                  {deg.url ? (
                    <a href={deg.url} target="_blank" rel="noopener noreferrer" class="edu-tl-inst-link">{deg.institution}</a>
                  ) : <span>{deg.institution}</span>}
                  {deg.location && <span class="edu-tl-sep-dot">·</span>}
                  {deg.location && <span class="edu-tl-location">{deg.location}</span>}
                </p>
                <p class="edu-tl-degree">
                  <span class="edu-tl-degree-name">{deg.degree}</span>
                  <span class="edu-tl-sep"> · </span>
                  <span class="edu-tl-field">{deg.field}</span>
                </p>
                <p class="edu-tl-period">{deg.period}</p>
                {advisorProse && (
                  <p class="edu-tl-advisor" set:html={advisorProse} />
                )}
              </div>
              {deg.logo && (
                <img src={deg.logo} alt={deg.institution} class="edu-tl-logo" onerror="this.style.display='none'" />
              )}
            </div>
          </div>
        );
      })}
    </div>
  </section>

  <!-- Tech Stack -->
  <section class="content-section" id="tech-stack">
    <h2>Tech Stack</h2>
    <div class="tech-logo-grid">
      {techStack.map((tool) => (
        <div class="tech-logo-item">
          {tool.logo ? (
            <img src={tool.logo} alt={tool.name} class="tech-logo-img" />
          ) : (
            <>
              <img src={tool.logoDark} alt={tool.name} class="tech-logo-img logo-dark-only" />
              <img src={tool.logoLight} alt={tool.name} class="tech-logo-img logo-light-only" />
            </>
          )}
          <span class="tech-logo-name">{tool.name}</span>
        </div>
      ))}
    </div>
  </section>

  <!-- MOOC Certificates -->
  <section class="content-section" id="certificates">
    <h2>Professional Certificates</h2>
    <div class="cert-grid">
      {certs.map((cert) => (
        <div class="cert-card">
          <div class="cert-card-img-wrap">
            {cert.image ? (
              <img
                src={`/assets/images/certificates/${cert.image}`}
                alt={cert.name}
                class="cert-card-img"
                loading="lazy"
                onerror="this.parentElement.innerHTML='<span class=\'cert-card-img-placeholder\'>📜</span>'"
              />
            ) : (
              <span class="cert-card-img-placeholder">📜</span>
            )}
          </div>
          <div class="cert-card-body">
            <p class="cert-card-name">{cert.name}</p>
            <p class="cert-card-institute">{cert.institute}</p>
            {cert.date && <p class="cert-card-date">{cert.date}</p>}
            {cert.link && (
              <a href={cert.link} target="_blank" rel="noopener noreferrer" class="cert-card-link">
                View certificate →
              </a>
            )}
          </div>
        </div>
      ))}
    </div>
  </section>
</MainLayout>
