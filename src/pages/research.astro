---
import MainLayout from '../layouts/MainLayout.astro';
import Hero from '../components/Hero.astro';
import ProjectsSection from '../components/ProjectsSection';
import projectsData from '../data/projects.json';

const allProjects = projectsData.projects;
---

<MainLayout
  title="Research | Farooq Olanrewaju"
  description="Research in geometric port-Hamiltonian systems, vehicle-manipulator systems, and physical human-robot interaction."
  activePage="research.html"
>
  <Hero
    slot="hero"
    variant="sm"
    title="Research Focus"
    subtitle="Geometric Port-Hamiltonian Systems & Vehicle-Manipulator Systems"
  />

  <section class="content-section">
    <h2>Research Overview</h2>
    <p>
      My research integrates <strong>geometric control theory</strong>,
      <strong>port-Hamiltonian systems</strong>, and <strong>differential geometry</strong>
      to solve complex problems in robotics and vehicle-manipulator systems.
    </p>
  </section>

  <section class="content-section">
    <h2>Core Methodologies</h2>
    <div class="methodology-grid">
      <div class="methodology-card">
        <h4>Geometric Control on SE(3)</h4>
        <p>Developing control algorithms that operate directly on the special Euclidean manifold for 3D motion and tracking.</p>
      </div>
      <div class="methodology-card">
        <h4>Port-Hamiltonian Framework</h4>
        <p>Energy-based modelling approach that preserves passivity and provides systematic control design methods.</p>
      </div>
      <div class="methodology-card">
        <h4>Vehicle-Manipulator Systems</h4>
        <p>Coordination of mobile bases with robotic arms, considering underactuation and energy efficiency.</p>
      </div>
    </div>
  </section>

  <section class="content-section">
    <h2>Application Domains</h2>
    <div class="interests-grid">
      <div class="interest-tag">Physical Human-Robot Interaction</div>
      <div class="interest-tag">Autonomous Vehicles</div>
      <div class="interest-tag">Underwater Robotics</div>
      <div class="interest-tag">Aerial Systems</div>
      <div class="interest-tag">Cooperative Robots</div>
      <div class="interest-tag">Energy Management</div>
    </div>
  </section>

  <section class="content-section">
    <h2>Advisor &amp; Institution</h2>
    <div class="info-card">
      <h4>King Fahd University of Petroleum and Minerals (KFUPM)</h4>
      <p>Department of Systems Engineering, Graduate Program</p>
      <p>
        <strong>Advisor:</strong>{' '}
        <a href="https://scholar.google.com/citations?user=M7fdYekAAAAJ" target="_blank" rel="noopener noreferrer">
          Dr. Ramy Rashad
        </a>
      </p>
      <p>
        <strong>Lab:</strong>{' '}
        <a href="https://ri.kfupm.edu.sa/irc-sml/facilities/arm4l-lab" target="_blank" rel="noopener noreferrer">
          ARM4L Lab
        </a>
      </p>
    </div>
  </section>

  <section class="content-section" id="projects">
    <h2>Projects</h2>
    <ProjectsSection client:visible projects={allProjects} showAll={true} />
  </section>

  <section class="content-section">
    <h2>Open to Collaboration</h2>
    <p>
      I'm actively seeking collaborations in geometric control, vehicle-manipulator systems,
      and safe physical HRI. If your research aligns with these areas, let's connect!
    </p>
    <div class="cta-buttons">
      <a href="https://www.linkedin.com/in/olanrewajufarooq/" class="cta-btn primary" target="_blank" rel="noopener noreferrer">
        Reach out on LinkedIn
      </a>
      <a href="/publications.html" class="cta-btn secondary">View Publications</a>
    </div>
  </section>
</MainLayout>
