---
import profileData from '../data/profile.json';

interface Props {
  activePage: string;
}

const { activePage } = Astro.props;
const profile = profileData as typeof profileData & {
  social: Array<{ label: string; href: string; icon?: string; iconClass?: string; emoji?: string }>;
};
---

<aside class="sidebar">
  <button class="sidebar-close" aria-label="Close sidebar">✕</button>

  <div class="sidebar-content">
    <!-- Identity -->
    <div class="sidebar-identity">
      <img src={profile.photo} alt={profile.name} class="sidebar-photo" />
      <h2 class="sidebar-name">{profile.name}</h2>
      <p class="sidebar-title">{profile.title}</p>
      <p class="sidebar-institution">{profile.institution}</p>
    </div>

    <!-- CV Download -->
    <div class="sidebar-cv">
      <a href="/assets/files/cv.pdf" download class="cv-download-btn" aria-label="Download CV">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" width="15" height="15" aria-hidden="true">
          <path d="M10.75 2.75a.75.75 0 0 0-1.5 0v8.614L6.295 8.235a.75.75 0 1 0-1.09 1.03l4.25 4.5a.75.75 0 0 0 1.09 0l4.25-4.5a.75.75 0 0 0-1.09-1.03l-2.955 3.129V2.75Z" />
          <path d="M3.5 12.75a.75.75 0 0 0-1.5 0v2.5A2.75 2.75 0 0 0 4.75 18h10.5A2.75 2.75 0 0 0 18 15.25v-2.5a.75.75 0 0 0-1.5 0v2.5c0 .69-.56 1.25-1.25 1.25H4.75c-.69 0-1.25-.56-1.25-1.25v-2.5Z" />
        </svg>
        Download CV
      </a>
    </div>

    <!-- Navigation -->
    <section class="sidebar-section">
      <h3>Navigation</h3>
      <nav class="sidebar-nav" aria-label="Site navigation">
        {profile.nav.map((item) => (
          <a
            href={`/${item.href}`}
            class={`nav-link${activePage === item.href ? ' active' : ''}`}
          >
            {item.label}
          </a>
        ))}
      </nav>
    </section>

    <!-- Connect -->
    <section class="sidebar-section">
      <h3>Connect</h3>
      <div class="social-links-sidebar">
        {profile.social.map((link) => (
          <a
            href={link.href}
            class={`social-link${link.iconClass ? ` ${link.iconClass}` : ''}`}
            target={link.href.startsWith('mailto:') ? undefined : '_blank'}
            rel={link.href.startsWith('mailto:') ? undefined : 'noopener noreferrer'}
          >
            {link.icon ? (
              <img src={link.icon} alt="" class="social-link-img" aria-hidden="true" />
            ) : (
              <span aria-hidden="true">{link.emoji ?? ''}</span>
            )}
            {link.label}
          </a>
        ))}
      </div>
    </section>
  </div>
</aside>
