---
interface Props {
  href: string;
  title?: string;
}

const { href, title } = Astro.props;
---

<a href={href} target="_blank" rel="noopener noreferrer" class="external-link" title={title}>
  <slot />
  <svg class="external-icon" viewBox="0 0 16 16" width="1em" height="1em" fill="currentColor">
    <path d="M8.5 1.5a.5.5 0 0 0-1 0v5a.5.5 0 0 0 1 0v-5z" />
    <path d="M6.5 3a.5.5 0 0 0 0 1h5a.5.5 0 0 0 .5-.5v-5a.5.5 0 0 0-1 0v4.5h-4.5z" />
  </svg>
</a>

<style>
  .external-link {
    display: inline-flex;
    align-items: center;
    gap: 0.25em;
    color: var(--color-link);
    text-decoration: none;
    transition: color var(--transition-fast);

    &:hover {
      color: var(--color-link-hover);
      text-decoration: underline;
    }

    &:focus-visible {
      outline: 2px solid var(--color-primary);
      outline-offset: 2px;
    }
  }

  .external-icon {
    flex-shrink: 0;
    opacity: 0.7;
  }
</style>
