---
interface Props {
  title: string;
  subtitle?: string;
  description?: string;
  backgroundImage?: string;
}

const { title, subtitle, description, backgroundImage } = Astro.props;
---

<header class="page-hero" style={backgroundImage ? `--bg-image: url(${backgroundImage})` : ''}>
  <div class="page-hero__content">
    <h1 class="page-hero__title">{title}</h1>
    {subtitle && <p class="page-hero__subtitle">{subtitle}</p>}
    {description && <p class="page-hero__description">{description}</p>}
  </div>
</header>

<style>
  .page-hero {
    padding: var(--space-12) var(--space-4);
    background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-secondary) 100%);
    color: var(--color-text-inverse);
    border-bottom: 1px solid var(--color-border);

    @media (min-width: var(--breakpoint-md)) {
      padding: var(--space-16) var(--space-8);
    }

    @media (min-width: var(--breakpoint-lg)) {
      padding: var(--space-20) var(--space-12);
    }
  }

  .page-hero__content {
    max-width: 1200px;
    margin: 0 auto;
  }

  .page-hero__title {
    margin: 0 0 var(--space-4) 0;
    font-size: var(--font-size-5xl);
    color: var(--color-text-inverse);

    @media (max-width: var(--breakpoint-md)) {
      font-size: var(--font-size-4xl);
    }
  }

  .page-hero__subtitle {
    margin: 0 0 var(--space-2) 0;
    font-size: var(--font-size-2xl);
    color: rgba(255, 255, 255, 0.9);
  }

  .page-hero__description {
    margin: 0;
    font-size: var(--font-size-lg);
    color: rgba(255, 255, 255, 0.8);
  }
</style>
