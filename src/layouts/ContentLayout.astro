---
import BaseLayout from './BaseLayout.astro';
import SiteShell from '../components/layout/SiteShell.astro';

interface Props {
  title: string;
  description: string;
  activePath: string;
  canonical?: string;
  ogImage?: string;
}

const { title, description, activePath, canonical, ogImage } = Astro.props;
---

<BaseLayout title={title} description={description} canonical={canonical} ogImage={ogImage}>
  <SiteShell activePath={activePath}>
    <slot />
  </SiteShell>
</BaseLayout>
